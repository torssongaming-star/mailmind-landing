<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides"
  xsi:type="MailApp">

  <Id>d3b1a2c3-4e5f-6a7b-8c9d-0e1f2a3b4c5d</Id>
  <Version>1.1.0.0</Version>
  <ProviderName>Mailmind</ProviderName>
  <DefaultLocale>sv-SE</DefaultLocale>
  <DisplayName DefaultValue="Mailmind" />
  <Description DefaultValue="Triage inkommande mejl med AI direkt i Outlook." />
  <IconUrl DefaultValue="https://mailmind.se/addins/outlook/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://mailmind.se/addins/outlook/icon-80.png" />
  <SupportUrl DefaultValue="https://mailmind.se/support" />

  <AppDomains>
    <AppDomain>https://mailmind.se</AppDomain>
    <AppDomain>https://www.mailmind.se</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <!--
    Mailbox 1.3 required for:
      - Office.context.mailbox.item.body.getAsync (read email body text)
    Mailbox 1.1 was the old minimum — insufficient for triage.
  -->
  <Requirements>
    <Sets DefaultMinVersion="1.3">
      <Set Name="Mailbox" MinVersion="1.3" />
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://mailmind.se/addins/outlook/" />
        <RequestedHeight>550</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <!-- ReadItem: read current message subject, sender, body — sufficient for triage -->
  <Permissions>ReadItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="And">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read" />
  </Rule>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Description resid="appDescription" />
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox" MinVersion="1.3" />
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="mailmindGroup">
                <Label resid="groupLabel" />
                <Control xsi:type="Button" id="mailmindTriageButton">
                  <Label resid="buttonLabel" />
                  <Supertip>
                    <Title resid="supertipTitle" />
                    <Description resid="supertipDescription" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16" />
                    <bt:Image size="32" resid="icon32" />
                    <bt:Image size="80" resid="icon80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="taskpaneUrl" />
                    <SupportsPinning>true</SupportsPinning>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="icon16" DefaultValue="https://mailmind.se/addins/outlook/icon-16.png" />
        <bt:Image id="icon32" DefaultValue="https://mailmind.se/addins/outlook/icon-32.png" />
        <bt:Image id="icon80" DefaultValue="https://mailmind.se/addins/outlook/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="taskpaneUrl" DefaultValue="https://mailmind.se/addins/outlook/" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="groupLabel"    DefaultValue="Mailmind" />
        <bt:String id="buttonLabel"   DefaultValue="Triage med Mailmind" />
        <bt:String id="supertipTitle" DefaultValue="Mailmind AI-triagering" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="appDescription"      DefaultValue="Triage inkommande mejl med AI direkt i Outlook." />
        <bt:String id="supertipDescription" DefaultValue="Öppna Mailmind-panelen för att klassificera och skapa AI-utkast till det markerade mejlet." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
