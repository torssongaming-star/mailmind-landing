<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp 
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" 
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" 
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0" 
  xsi:type="MailApp">
  
  <Id>d3b1a2c3-4e5f-6a7b-8c9d-0e1f2a3b4c5d</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Mailmind</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Mailmind" />
  <Description DefaultValue="AI-powered email triage and drafting for Outlook." />
  
  <IconUrl DefaultValue="https://localhost:3000/addins/outlook/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://localhost:3000/addins/outlook/icon-80.png" />
  
  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>
  
  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="Mailbox" />
    </Sets>
  </Requirements>
  
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://localhost:3000/addins/outlook" />
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>
  
  <Permissions>ReadItem</Permissions>
  
  <Rule xsi:type="RuleCollection" Mode="And">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read" />
  </Rule>
  
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.0" xsi:type="VersionOverridesV1_0">
    <Description DefaultValue="AI-powered email triage and drafting for Outlook." />
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup">
                <Label DefaultValue="Mailmind" />
                <Control xsi:type="Button" id="msgReadOpenPaneButton">
                  <Label DefaultValue="Open Mailmind" />
                  <Supertip>
                    <Title DefaultValue="Mailmind" />
                    <Description DefaultValue="Open the Mailmind taskpane to manage your email with AI." />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16" />
                    <bt:Image size="32" resid="icon32" />
                    <bt:Image size="80" resid="icon80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="taskpaneUrl" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="icon16" DefaultValue="https://localhost:3000/addins/outlook/icon-16.png" />
        <bt:Image id="icon32" DefaultValue="https://localhost:3000/addins/outlook/icon-32.png" />
        <bt:Image id="icon80" DefaultValue="https://localhost:3000/addins/outlook/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="taskpaneUrl" DefaultValue="https://localhost:3000/addins/outlook" />
      </bt:Urls>
    </Resources>
  </VersionOverrides>
</OfficeApp>
