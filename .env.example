# ── Clerk Authentication ──────────────────────────────────────────────────────
# Get these from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk webhook signing secret (Clerk Dashboard → Webhooks → your endpoint)
# TODO (Phase 3): Enable Clerk webhooks to sync user lifecycle events to DB
CLERK_WEBHOOK_SECRET=

# Clerk redirect URLs — do not change these unless you rename the routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# ── Stripe Billing ────────────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com → Developers → API keys
# Use sk_test_* / pk_test_* in development, sk_live_* / pk_live_* in production
# Restricted keys (rk_*) are also supported if they have the required permissions:
#   Customers (read/write), Checkout Sessions (write), Billing Portal (write),
#   Subscriptions (read/write), Webhooks (read)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe webhook signing secret (Stripe Dashboard → Webhooks → your endpoint)
# TODO (Phase 3): Register endpoint and add to Stripe Dashboard:
#   Events to listen for:
#     - checkout.session.completed
#     - customer.subscription.updated
#     - customer.subscription.deleted
#     - invoice.payment_failed
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — create these in Stripe Dashboard → Products
# TODO (Phase 2): Fill these in once products are created in Stripe Dashboard
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_TEAM=
STRIPE_PRICE_ID_BUSINESS=

# ── App ───────────────────────────────────────────────────────────────────────
# Production URL used for Stripe redirect URLs (no trailing slash)
NEXT_PUBLIC_APP_URL=https://mailmind.se

# ── Database ──────────────────────────────────────────────────────────────────
# Connection string from: https://console.neon.tech → your project
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# ── Resend (Demo Requests) ──────────────────────────────────────────────────
RESEND_API_KEY=
DEMO_REQUEST_TO=
DEMO_REQUEST_FROM=

